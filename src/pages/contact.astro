---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/NavBar.astro";
import "../styles/contact.css";
---

<BaseLayout title="Contact">
  <Navbar />

  <main class="page-contact">
    <div class="contact-container">
      <h1>Contact</h1>
      <p class="contact-sub">N'hésitez pas à me contacter !</p>

      <div class="contact-card">

        <!-- Email -->
        <div class="contact-item">
          <span class="contact-icon">
            <svg viewBox="0 0 24 24" fill="#7DD3FC" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </span>
          <div>
            <p class="contact-label">Email</p>
            <a href="mailto:maya.guy@msomg.fr" target="_self">maya.guy@msomg.fr</a>
          </div>
        </div>

        <!-- LinkedIn -->
        <div class="contact-item">
          <span class="contact-icon">
            <svg viewBox="0 0 24 24" fill="#7DD3FC" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 0h-14c-2.76 0-5 2.24-5 5v14c0 2.76 2.24 5 5 5h14c2.762 0 5-2.24 5-5v-14c0-2.76-2.238-5-5-5zm-11.75 20h-3v-10h3v10zm-1.5-11.27c-.966 0-1.75-.79-1.75-1.76 0-.97.784-1.75 1.75-1.75s1.75.78 1.75 1.75c0 .97-.784 1.76-1.75 1.76zm13.25 11.27h-3v-5.5c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.44-2.13 2.93v5.61h-3v-10h2.88v1.36h.04c.4-.76 1.37-1.56 2.82-1.56 3.02 0 3.58 1.99 3.58 4.57v5.63z"/>
            </svg>
          </span>
          <div>
            <p class="contact-label">LinkedIn</p>
            <a href="https://www.linkedin.com/in/maya-guy-msomg/" target="_blank" rel="noopener">LinkedIn</a>
          </div>
        </div>

        <!-- GitHub -->
        <div class="contact-item">
          <span class="contact-icon">
            <svg viewBox="0 0 24 24" fill="#7DD3FC" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.26.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.334-1.757-1.334-1.757-1.09-.745.083-.73.083-.73 1.205.085 1.84 1.236 1.84 1.236 1.07 1.834 2.805 1.304 3.49.997.108-.775.418-1.305.76-1.605-2.665-.3-5.467-1.332-5.467-5.932 0-1.31.47-2.38 1.236-3.22-.124-.303-.536-1.523.117-3.176 0 0 1.008-.322 3.3 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.29-1.552 3.296-1.23 3.296-1.23.655 1.653.243 2.873.12 3.176.77.84 1.234 1.91 1.234 3.22 0 4.61-2.807 5.628-5.48 5.922.43.372.814 1.104.814 2.225 0 1.606-.014 2.9-.014 3.293 0 .32.216.694.825.576C20.565 21.796 24 17.3 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </span>
          <div>
            <p class="contact-label">GitHub</p>
            <a href="https://github.com/GuyMaya" target="_blank" rel="noopener">GitHub</a>
          </div>
        </div>

      </div>
    </div>
  </main>
</BaseLayout>